<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="?android:attr/windowBackground">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/settings"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="?android:attr/textColorPrimary"
        android:importantForAccessibility="yes"
        android:contentDescription="@string/settings"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/font_size"
        android:textColor="?android:attr/textColorPrimary"
        android:textSize="18sp"
        android:layout_marginTop="16dp"/>

    <RadioGroup
        android:id="@+id/radioGroupFontSize"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">
        <RadioButton
            android:id="@+id/radioNormal"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:minHeight="48dp"
            android:textColor="?android:attr/textColorPrimary"
            android:text="@string/font_size_normal"/>
        <RadioButton
            android:id="@+id/radioLarge"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:minHeight="48dp"
            android:textColor="?android:attr/textColorPrimary"
            android:text="@string/font_size_large"/>
        <RadioButton
            android:id="@+id/radioHuge"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:minHeight="48dp"
            android:textColor="?android:attr/textColorPrimary"
            android:text="@string/font_size_huge"/>
    </RadioGroup>

    <Switch
        android:id="@+id/switchHighContrast"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:minHeight="48dp"
        android:textColor="?android:attr/textColorPrimary"
        android:text="@string/high_contrast"
        android:textSize="18sp"
        android:layout_marginTop="24dp"/>

    <Switch
        android:id="@+id/switchSimpleLanguage"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:minHeight="48dp"
        android:textColor="?android:attr/textColorPrimary"
        android:text="@string/simple_language"
        android:textSize="18sp"
        android:layout_marginTop="16dp"/>

    <Switch
        android:id="@+id/switchVoiceReader"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:minHeight="48dp"
        android:textColor="?android:attr/textColorPrimary"
        android:text="@string/voice_reader"
        android:textSize="18sp"
        android:layout_marginTop="16dp"/>

    <Button
        android:id="@+id/btnBack"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="@string/back"
        android:textColor="?attr/colorOnPrimary"
        android:layout_marginTop="32dp"/>
</LinearLayout>
